        .icon-wrapper {
            position: relative;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--dark-surface);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-text);
            text-decoration: none;
            transition: var(--transition-normal);
            border: 1px solid transparent;
        }
        
        .icon-wrapper:hover {
            color: var(--light-text);
            border-color: var(--primary-color);
            box-shadow: var(--shadow-neon);
            transform: translateY(-2px);
        }
        
        .cart-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--gradient-primary);
            color: white;
            font-size: 12px;
            font-weight: 700;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Breadcrumb dengan style modern */
        .breadcrumb {
            padding: 20px 0;
            background: var(--gradient-dark);
            margin-bottom: 40px;
        }
        
        .breadcrumb-content {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .breadcrumb-item {
            display: flex;
            align-items: center;
            color: var(--gray-text);
            text-decoration: none;
            transition: var(--transition-normal);
            padding: 5px 10px;
            border-radius: var(--radius-sm);
        }
        
        .breadcrumb-item:hover {
            color: var(--light-text);
            background: rgba(138, 43, 226, 0.1);
        }
        
        .breadcrumb-separator {
            margin: 0 10px;
            color: var(--primary-color);
        }
        
        .breadcrumb-current {
            color: var(--light-text);
            font-weight: 600;
            padding: 5px 15px;
            background: rgba(138, 43, 226, 0.2);
            border-radius: var(--radius-sm);
            border-left: 3px solid var(--primary-color);
        }
        
        /* Main Product Layout - Asymmetric Design */
        .product-main {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 50px;
            margin-bottom: 60px;
        }
        
        /* Product Gallery - Carousel dengan efek */
        .product-gallery {
            position: relative;
        }
        
        .main-image-container {
            position: relative;
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            margin-bottom: 20px;
            background: var(--dark-card);
            border: 1px solid var(--border-color);
        }
        
        .main-image {
            width: 100%;
            height: 500px;
            object-fit: contain;
            padding: 20px;
            transition: var(--transition-slow);
        }
        
        .image-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--gradient-primary);
            color: white;
            padding: 8px 15px;
            border-radius: var(--radius-lg);
            font-weight: 700;
            font-size: 14px;
            box-shadow: var(--shadow-neon);
        }
        
        /* Thumbnail gallery dengan hover effect */
        .thumbnail-gallery {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }
        
        .thumbnail {
            border-radius: var(--radius-md);
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: var(--transition-normal);
            background: var(--dark-card);
            height: 100px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .thumbnail.active {
            border-color: var(--primary-color);
            box-shadow: var(--shadow-neon);
            transform: translateY(-5px);
        }
        
        .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition-normal);
        }
        
        .thumbnail:hover img {
            transform: scale(1.1);
        }
        
        /* Product Info - Card dengan efek glass */
        .product-info-card {
            background: rgba(30, 30, 46, 0.8);
            backdrop-filter: blur(10px);
            border-radius: var(--radius-xl);
            padding: 40px;
            box-shadow: var(--shadow-card);
            border: 1px solid var(--border-color);
            position: sticky;
            top: 100px;
        }
        
        .product-title {
            font-size: 32px;
            margin-bottom: 10px;
            background: linear-gradient(90deg, var(--light-text), var(--primary-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .product-subtitle {
            color: var(--gray-text);
            font-size: 18px;
            margin-bottom: 20px;
        }
        
        /* Rating dengan stars animasi */
        .product-rating {
            display: flex;
            align-items: center;
            margin-bottom: 25px;
        }
        
        .stars {
            display: flex;
            gap: 5px;
            margin-right: 15px;
        }
        
        .star {
            color: var(--warning-color);
            font-size: 20px;
            transition: var(--transition-normal);
        }
        
        .star:hover {
            transform: scale(1.3);
        }
        
        .rating-count {
            color: var(--gray-text);
            font-size: 14px;
        }
        
        .rating-link {
            color: var(--secondary-color);
            text-decoration: none;
            margin-left: 10px;
            font-size: 14px;
        }
        
        .rating-link:hover {
            text-decoration: underline;
        }
        
        /* Price dengan animasi */
        .product-price-container {
            margin-bottom: 30px;
            padding: 20px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: var(--radius-lg);
            border-left: 4px solid var(--primary-color);
        }
        
        .current-price {
            font-size: 42px;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-right: 15px;
        }
        
        .original-price {
            font-size: 24px;
            color: var(--gray-text);
            text-decoration: line-through;
            margin-right: 15px;
        }
        
        .discount-badge {
            display: inline-block;
            background: var(--gradient-secondary);
            color: var(--dark-bg);
            padding: 5px 12px;
            border-radius: var(--radius-lg);
            font-weight: 700;
            font-size: 14px;
            box-shadow: var(--shadow-neon-secondary);
        }
        
        /* Product features dengan icon */
        .product-features {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .feature-item {
            display: flex;
            align-items: center;
            padding: 15px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-md);
            transition: var(--transition-normal);
        }
        
        .feature-item:hover {
            background: rgba(138, 43, 226, 0.1);
            transform: translateX(5px);
        }
        
        .feature-icon {
            width: 40px;
            height: 40px;
            background: var(--gradient-primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            color: white;
            font-size: 18px;
        }
        
        /* Product options dengan toggle */
        .product-options {
            margin-bottom: 30px;
        }
        
        .option-group {
            margin-bottom: 25px;
        }
        
        .option-title {
            font-size: 18px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }
        
        .option-title i {
            margin-right: 10px;
            color: var(--primary-color);
        }
        
        /* PERBAIKAN BAGIAN "PILIH WARNA" - FIXED */
        .color-options {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }
        
        .color-option {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            transition: var(--transition-normal);
            padding: 10px;
            border-radius: var(--radius-md);
            border: 2px solid transparent;
            min-width: 80px;
        }
        
        .color-option:hover {
            background: rgba(138, 43, 226, 0.1);
        }
        
        .color-option.selected {
            background: rgba(138, 43, 226, 0.2);
            border-color: var(--primary-color);
        }
        
        .color-sample {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            margin-bottom: 8px;
            border: 3px solid var(--border-color);
            transition: var(--transition-normal);
        }
        
        .color-option.selected .color-sample {
            border-color: var(--light-text);
            box-shadow: var(--shadow-neon);
            transform: scale(1.1);
        }
        
        .color-name {
            font-size: 12px;
            text-align: center;
            color: var(--gray-text);
            line-height: 1.4;
            max-width: 70px;
            word-wrap: break-word;
        }
        
        /* Storage Options - FIXED */
        .storage-options {
            display: flex;
            gap: 15px;
            margin-top: 10px;
        }
        
        .storage-option {
            padding: 12px 24px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--border-color);
            border-radius: var(--radius-lg);
            color: var(--gray-text);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition-normal);
            font-size: 16px;
        }
        
        .storage-option:hover {
            background: rgba(138, 43, 226, 0.1);
            color: var(--light-text);
            transform: translateY(-2px);
        }
        
        .storage-option.selected {
            background: var(--gradient-primary);
            color: white;
            border-color: var(--primary-color);
            box-shadow: var(--shadow-neon);
        }
        
        /* Quantity dengan style futuristik */
        .quantity-selector {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-lg);
            padding: 5px;
            width: fit-content;
            margin-bottom: 25px;
        }
        
        .quantity-btn {
            width: 45px;
            height: 45px;
            background: var(--dark-surface);
            border: none;
            border-radius: var(--radius-md);
            color: var(--light-text);
            font-size: 20px;
            cursor: pointer;
            transition: var(--transition-normal);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .quantity-btn:hover {
            background: var(--primary-color);
            transform: scale(1.1);
        }
        
        .quantity-input {
            width: 70px;
            height: 45px;
            background: transparent;
            border: none;
            text-align: center;
            color: var(--light-text);
            font-size: 18px;
            font-weight: 600;
        }
        
        /* Payment Methods Section */
        .payment-methods {
            padding: 20px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            margin: 25px 0;
            border: 1px solid var(--border-color);
        }
        
        .payment-title {
            font-size: 16px;
            color: var(--gray-text);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }
        
        .payment-title i {
            margin-right: 10px;
            color: var(--success-color);
        }
        
        .payment-logos {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            align-items: center;
        }
        
        .payment-logo {
            height: 30px;
            width: auto;
            filter: grayscale(100%);
            opacity: 0.7;
            transition: var(--transition-normal);
        }
        
        .payment-logo:hover {
            filter: grayscale(0%);
            opacity: 1;
            transform: translateY(-2px);
        }
        
        /* Action buttons dengan efek glow */
        .action-buttons {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .btn {
            padding: 18px 30px;
            border-radius: var(--radius-lg);
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: var(--transition-normal);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
        }
        
        .btn-primary {
            background: var(--gradient-primary);
            color: white;
            box-shadow: var(--shadow-neon);
        }
        
        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 10px 25px rgba(138, 43, 226, 0.5);
        }
        
        .btn-secondary {
            background: transparent;
            color: var(--light-text);
            border: 2px solid var(--primary-color);
        }
        
        .btn-secondary:hover {
            background: rgba(138, 43, 226, 0.1);
            transform: translateY(-3px) scale(1.02);
        }
        
        .btn-wishlist {
            background: rgba(255, 255, 255, 0.05);
            color: var(--light-text);
        }
        
        .btn-wishlist:hover {
            background: rgba(255, 0, 255, 0.1);
            color: var(--accent-color);
            transform: translateY(-3px) scale(1.02);
        }
        
        /* One-Click Checkout */
        .quick-checkout {
            margin-top: 15px;
            padding: 15px;
            background: rgba(0, 217, 255, 0.05);
            border-radius: var(--radius-md);
        }
        
        /* Product details dengan tabs */
        .product-details {
            margin-bottom: 60px;
        }
        
        .details-tabs {
            display: flex;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 30px;
        }
        
        .tab-btn {
            padding: 20px 30px;
            background: transparent;
            border: none;
            color: var(--gray-text);
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            position: relative;
            transition: var(--transition-normal);
        }
        
        .tab-btn:hover {
            color: var(--light-text);
        }
        
        .tab-btn.active {
            color: var(--light-text);
        }
        
        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 100%;
            height: 3px;
            background: var(--gradient-primary);
        }
        
        .tab-content {
            background: var(--dark-card);
            border-radius: var(--radius-xl);
            padding: 40px;
            box-shadow: var(--shadow-card);
        }
        
        /* Specifications dengan tabel modern */
        .specs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .spec-item {
            display: flex;
            justify-content: space-between;
            padding: 15px 0;
            border-bottom: 1px solid var(--border-color);
        }
        
        .spec-label {
            color: var(--gray-text);
            font-weight: 500;
        }
        
        .spec-value {
            color: var(--light-text);
            font-weight: 600;
        }
        
        /* Reviews dengan card */
        .review-card {
            background: rgba(255, 255, 255, 0.03);
            border-radius: var(--radius-lg);
            padding: 25px;
            margin-bottom: 20px;
            border-left: 4px solid var(--primary-color);
        }
        
        .review-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        
        .review-author {
            font-weight: 600;
            color: var(--light-text);
        }
        
        .review-date {
            color: var(--gray-text);
            font-size: 14px;
        }
        
        /* Related products dengan carousel effect */
        .related-products {
            margin-bottom: 80px;
        }
        
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }
        
        .section-title {
            font-size: 32px;
            background: linear-gradient(90deg, var(--light-text), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .section-link {
            color: var(--secondary-color);
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .section-link:hover {
            text-decoration: underline;
        }
        
        .products-carousel {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }
        
        .product-card {
            background: var(--dark-card);
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            transition: var(--transition-normal);
            border: 1px solid transparent;
        }
        
        .product-card:hover {
            transform: translateY(-10px);
            border-color: var(--primary-color);
            box-shadow: var(--shadow-hover);
        }
        
        .product-card-img {
            height: 200px;
            overflow: hidden;
            position: relative;
        }
        
        .product-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition-slow);
        }
        
        .product-card:hover .product-card-img img {
            transform: scale(1.1);
        }
        
        .product-card-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: var(--gradient-primary);
            color: white;
            padding: 5px 12px;
            border-radius: var(--radius-lg);
            font-size: 12px;
            font-weight: 700;
        }
        
        .product-card-info {
            padding: 25px;
        }
        
        .product-card-title {
            font-size: 18px;
            margin-bottom: 10px;
            color: var(--light-text);
            text-decoration: none;
            display: block;
        }
        
        .product-card-title:hover {
            color: var(--primary-light);
        }
        
        .product-card-price {
            font-size: 24px;
            font-weight: 700;
            color: var(--primary-color);
            margin-bottom: 15px;
        }
        
        .product-card-rating {
            display: flex;
            align-items: center;
            gap: 5px;
            margin-bottom: 15px;
        }
        
        /* Footer dengan gradient */
        footer {
            background: var(--gradient-dark);
            padding: 60px 0 30px;
            border-top: 1px solid var(--border-color);
        }
        
        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 40px;
            margin-bottom: 40px;
        }
        
        .footer-logo-section {
            display: flex;
            flex-direction: column;
        }
        
        .footer-logo {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .footer-logo img {
            height: 50px;
            width: auto;
            margin-right: 15px;
        }
        
        .footer-logo-text {
            font-size: 28px;
            font-weight: 700;
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .footer-description {
            color: var(--gray-text);
            margin-bottom: 25px;
            line-height: 1.8;
        }
        
        .social-links {
            display: flex;
            gap: 15px;
        }
        
        .social-link {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--dark-surface);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray-text);
            text-decoration: none;
            transition: var(--transition-normal);
        }
        
        .social-link:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-3px);
        }
        
        .footer-column h3 {
            font-size: 20px;
            margin-bottom: 25px;
            color: var(--light-text);
        }
        
        .footer-links {
            list-style: none;
        }
        
        .footer-links li {
            margin-bottom: 15px;
        }
        
        .footer-links a {
            color: var(--gray-text);
            text-decoration: none;
            transition: var(--transition-normal);
            display: flex;
            align-items: center;
        }
        
        .footer-links a:hover {
            color: var(--primary-light);
            transform: translateX(5px);
        }
        
        .footer-links i {
            margin-right: 10px;
            width: 20px;
        }
        
        .newsletter-form {
            position: relative;
        }
        
        .newsletter-input {
            width: 100%;
            padding: 16px 20px;
            background: var(--dark-surface);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-lg);
            color: var(--light-text);
            font-size: 16px;
            margin-bottom: 15px;
        }
        
        .newsletter-input:focus {
            outline: none;
            border-color: var(--primary-color);
        }
        
        /* Security Badges */
        .security-badges {
            text-align: center;
            margin: 30px 0;
            padding: 20px;
            background: rgba(0, 255, 157, 0.05);
            border-radius: var(--radius-lg);
        }
        
        .security-badges h4 {
            margin-bottom: 20px;
            color: var(--success-color);
        }
        
        .badge-container {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .badge-item {
            text-align: center;
        }
        
        .badge-icon {
            width: 50px;
            height: 50px;
            background: var(--dark-surface);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            color: var(--success-color);
            font-size: 24px;
        }
        
        .copyright {
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid var(--border-color);
            color: var(--gray-text);
            font-size: 14px;
        }
        
        /* Footer Payment Methods */
        .footer-payment {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .footer-payment-title {
            color: var(--gray-text);
            font-size: 14px;
            margin-bottom: 15px;
            text-align: center;
        }
        
        .footer-payment-logos {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .footer-payment-logo {
            height: 25px;
            width: auto;
            opacity: 0.8;
            transition: var(--transition-normal);
        }
        
        .footer-payment-logo:hover {
            opacity: 1;
            transform: translateY(-2px);
        }
        
        /* Responsive Design */
        @media (max-width: 1200px) {
            .product-main {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            
            .product-info-card {
                position: static;
            }
        }
        
        @media (max-width: 992px) {
            .nav-container {
                display: none;
            }
            
            .search-container {
                width: 200px;
            }
            
            .thumbnail-gallery {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .payment-logos {
                justify-content: center;
            }
            
            .color-options {
                gap: 15px;
            }
            
            .color-option {
                min-width: 70px;
