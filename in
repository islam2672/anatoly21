                item.getAttribute('id') === autocompleteList.getAttribute('aria-activedescendant')
            );
            
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                activeIndex = (activeIndex + 1) % items.length;
                autocompleteList.setAttribute('aria-activedescendant', `option-${activeIndex}`);
                items[activeIndex].focus();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                activeIndex = (activeIndex - 1 + items.length) % items.length;
                autocompleteList.setAttribute('aria-activedescendant', `option-${activeIndex}`);
                items[activeIndex].focus();
            } else if (e.key === 'Enter' && activeIndex >= 0) {
                e.preventDefault();
                items[activeIndex].click();
            } else if (e.key === 'Escape') {
                autocompleteList.style.display = 'none';
                autocompleteList.setAttribute('aria-expanded', 'false');
